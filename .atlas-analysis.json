  "publicApiSurface": [
    "GET /eventos — listagem pública de eventos disponíveis",
    "POST /cadastro — criação de conta (participante ou organizador)",
    "POST /login — autenticação na plataforma",
    "GET /minha-conta/ingressos — ingressos do participante autenticado",
    "POST /checkout — processamento de compra de ingressos",
    "GET /para-produtores — página informativa para organizadores",
    "POST /promotores — cadastro no programa de promotores",
